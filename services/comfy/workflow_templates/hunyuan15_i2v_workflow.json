{
  "1": {
    "class_type": "CLIPVisionLoader",
    "inputs": {
      "clip_name": "__CLIP_VISION_NAME__"
    }
  },
  "2": {
    "class_type": "DualCLIPLoader",
    "inputs": {
      "clip_name1": "__TEXT_ENCODER_1__",
      "clip_name2": "__TEXT_ENCODER_2__",
      "type": "hunyuan_video_15",
      "device": "default"
    }
  },
  "3": {
    "class_type": "VAELoader",
    "inputs": {
      "vae_name": "__VAE_NAME__"
    }
  },
  "4": {
    "class_type": "UNETLoader",
    "inputs": {
      "unet_name": "__DIFFUSION_MODEL__",
      "weight_dtype": "__WEIGHT_DTYPE__"
    }
  },
  "5": {
    "class_type": "LoadImage",
    "inputs": {
      "image": "__INPUT_IMAGE__"
    }
  },
  "6": {
    "class_type": "CLIPVisionEncode",
    "inputs": {
      "crop": "center",
      "clip_vision": ["1", 0],
      "image": ["5", 0]
    }
  },
  "7": {
    "class_type": "CLIPTextEncode",
    "inputs": {
      "text": __PROMPT_JSON__,
      "clip": ["2", 0]
    }
  },
  "8": {
    "class_type": "CLIPTextEncode",
    "inputs": {
      "text": __NEGATIVE_PROMPT_JSON__,
      "clip": ["2", 0]
    }
  },
  "9": {
    "class_type": "HunyuanVideo15ImageToVideo",
    "inputs": {
      "width": __WIDTH__,
      "height": __HEIGHT__,
      "length": __FRAMES__,
      "batch_size": 1,
      "positive": ["7", 0],
      "negative": ["8", 0],
      "vae": ["3", 0],
      "start_image": ["5", 0],
      "clip_vision_output": ["6", 0]
    }
  },
  "10": {
    "class_type": "ModelSamplingSD3",
    "inputs": {
      "shift": __SHIFT__,
      "model": ["4", 0]
    }
  },
  "11": {
    "class_type": "BasicScheduler",
    "inputs": {
      "scheduler": "simple",
      "steps": __STEPS__,
      "denoise": 1,
      "model": ["10", 0]
    }
  },
  "12": {
    "class_type": "RandomNoise",
    "inputs": {
      "noise_seed": __SEED__
    }
  },
  "13": {
    "class_type": "KSamplerSelect",
    "inputs": {
      "sampler_name": "euler"
    }
  },
  "14": {
    "class_type": "CFGGuider",
    "inputs": {
      "cfg": __CFG__,
      "model": ["10", 0],
      "positive": ["9", 0],
      "negative": ["9", 1]
    }
  },
  "15": {
    "class_type": "SamplerCustomAdvanced",
    "inputs": {
      "noise": ["12", 0],
      "guider": ["14", 0],
      "sampler": ["13", 0],
      "sigmas": ["11", 0],
      "latent_image": ["9", 2]
    }
  },
  "16": {
    "class_type": "VAEDecode",
    "inputs": {
      "samples": ["15", 0],
      "vae": ["3", 0]
    }
  },
  "17": {
    "class_type": "VHS_VideoCombine",
    "inputs": {
      "frame_rate": __FPS__,
      "loop_count": 0,
      "filename_prefix": "__OUTPUT_PREFIX__",
      "format": "video/h264-mp4",
      "pix_fmt": "yuv420p",
      "crf": 20,
      "pingpong": false,
      "save_output": true,
      "images": ["16", 0]
    }
  }
}
