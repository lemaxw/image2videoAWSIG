{
  "1": {
    "class_type": "CheckpointLoaderSimple",
    "inputs": {
      "ckpt_name": "__CKPT_NAME__"
    }
  },
  "2": {
    "class_type": "LoadImage",
    "inputs": {
      "image": "__INPUT_IMAGE__"
    }
  },
  "3": {
    "class_type": "CLIPTextEncode",
    "inputs": {
      "text": "__PROMPT__",
      "clip": ["1", 1]
    }
  },
  "4": {
    "class_type": "CLIPTextEncode",
    "inputs": {
      "text": "__NEGATIVE_PROMPT__",
      "clip": ["1", 1]
    }
  },
  "5": {
    "class_type": "ImageScale",
    "inputs": {
      "image": ["2", 0],
      "width": __WIDTH__,
      "height": __HEIGHT__,
      "upscale_method": "lanczos",
      "crop": "disabled"
    }
  },
  "6": {
    "class_type": "VAEEncode",
    "inputs": {
      "pixels": ["5", 0],
      "vae": ["1", 2]
    }
  },
  "7": {
    "class_type": "RepeatLatentBatch",
    "inputs": {
      "samples": ["6", 0],
      "amount": __FRAMES__
    }
  },
  "8": {
    "class_type": "ADE_LoadAnimateDiffModel",
    "inputs": {
      "model_name": "__MOTION_MODULE__"
    }
  },
  "9": {
    "class_type": "ADE_ApplyAnimateDiffModelSimple",
    "inputs": {
      "motion_model": ["8", 0]
    }
  },
  "10": {
    "class_type": "ADE_StandardStaticContextOptions",
    "inputs": {
      "context_length": __CONTEXT_LENGTH__,
      "context_overlap": __CONTEXT_OVERLAP__
    }
  },
  "11": {
    "class_type": "ADE_UseEvolvedSampling",
    "inputs": {
      "model": ["1", 0],
      "beta_schedule": "sqrt_linear (AnimateDiff)",
      "m_models": ["9", 0],
      "context_options": ["10", 0]
    }
  },
  "12": {
    "class_type": "KSampler",
    "inputs": {
      "seed": __SEED__,
      "steps": __STEPS__,
      "cfg": __CFG__,
      "sampler_name": "euler",
      "scheduler": "normal",
      "denoise": __DENOISE__,
      "model": ["11", 0],
      "positive": ["3", 0],
      "negative": ["4", 0],
      "latent_image": ["7", 0]
    }
  },
  "13": {
    "class_type": "VAEDecode",
    "inputs": {
      "samples": ["12", 0],
      "vae": ["1", 2]
    }
  },
  "14": {
    "class_type": "VHS_VideoCombine",
    "inputs": {
      "frame_rate": __FPS__,
      "loop_count": 0,
      "filename_prefix": "__OUTPUT_PREFIX__",
      "format": "video/h264-mp4",
      "pix_fmt": "yuv420p",
      "crf": 18,
      "pingpong": false,
      "save_output": true,
      "images": ["13", 0]
    }
  }
}
